# Copy to .env and fill in your token. NEVER commit .env.
# The DataHub MCP endpoint (a tushare gateway). URL is hard-coded in mcp_client.py;
# override here only if you run your own.
# DATAHUB_MCP_URL=http://your-datahub-host:8010/mcp

# Required. Your bearer token for the MCP gateway.
DATAHUB_MCP_TOKEN=Bearer your_token_here
